{
  "manifest_version": 3,
  "name": "asdf",
  "version": "3.0.0",
  "description": "asdf",
  "action": {},
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["activeTab", "identity", "identity.email", "scripting", "storage"],
  "options_ui": {
    "page": "src/options.html",
